---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/site";
---

<Layout
  title="Projects | Athulya Ratnayake"
  description="Projects spanning remote sensing, demographic analysis, heritage restoration, and INR research."
  currentPath="/projects"
>
  <div class="page-stack">
    <section class="hero-card">
      <div class="hero-copy">
        <span class="eyebrow">Applied Research</span>
        <h1>Projects</h1>
        <div class="pill-row">
          <span class="pill">Remote sensing</span>
          <span class="pill">Heritage restoration</span>
          <span class="pill">Demographic analytics</span>
          <span class="pill">INR theory</span>
        </div>
      </div>

      <aside class="profile-card">
        <span class="eyebrow">Project Lens</span>
        <h3>What ties them together</h3>
        <p>
          These projects share a consistent through-line: strong mathematical grounding paired with practical
          engineering solutions for noisy, high-dimensional, or structurally complex systems.
        </p>
      </aside>
    </section>

    <section class="content-card">
      <div class="section-heading">
        <span class="eyebrow">Portfolio</span>
        <h2>Research and engineering projects</h2>
        <p>
          The timeline below focuses on the core problem, technical contribution, and research direction of
          each project.
        </p>
      </div>

      <div class="projects-grid">
        {
          projects.map((project) => (
            <article class="timeline-card">
              <div class="meta-row">
                <span class="timeline-card__date">{project.period}</span>
                <span class="meta-chip">{project.category}</span>
              </div>
              <strong>{project.title}</strong>
              <ul class="clean-list">
                {project.highlights.map((point) => <li>{point}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</Layout>
