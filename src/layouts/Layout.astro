---
const {
  title = "Athulya Ratnayake | Portfolio",
  description = "Research portfolio featuring profile, publications, projects, and articles.",
  currentPath = "/",
} = Astro.props;

const withBase = (path) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;

const navigation = [
  { path: "/", href: withBase("/"), label: "Profile" },
  { path: "/publications", href: withBase("/publications"), label: "Publications" },
  { path: "/projects", href: withBase("/projects"), label: "Projects" },
  { path: "/achievements", href: withBase("/achievements"), label: "Achievements" },
  { path: "/articles", href: withBase("/articles"), label: "Articles" },
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      const storedTheme = localStorage.getItem("portfolio-theme");
      const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = storedTheme ?? (systemPrefersDark ? "dark" : "light");
    </script>
  </head>
  <body>
    <div class="site-shell">
      <div class="ambient ambient-one"></div>
      <div class="ambient ambient-two"></div>

      <header class="site-header">
        <a class="brand" href={withBase("/")}>
          <span class="brand-mark brand-mark--image">
            <img src={withBase("/me.jpeg")} alt="Athulya Ratnayake" />
          </span>
          <span class="brand-copy">
            <strong>Athulya Ratnayake</strong>
            <small>Research Portfolio</small>
          </span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          {
            navigation.map((item) => (
              <a class={currentPath === item.path ? "active" : ""} href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>

        <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>
          <span class="theme-toggle__track">
            <span class="theme-toggle__icon theme-toggle__icon--sun">Light</span>
            <span class="theme-toggle__icon theme-toggle__icon--moon">Dark</span>
          </span>
        </button>
      </header>

      <main class="page-frame">
        <slot />
      </main>

      <footer class="site-footer"></footer>
    </div>

    <script is:inline>
      const toggle = document.querySelector("[data-theme-toggle]");
      const root = document.documentElement;
      toggle?.addEventListener("click", () => {
        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = nextTheme;
        localStorage.setItem("portfolio-theme", nextTheme);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f4efe7;
    --bg-elevated: rgba(255, 250, 244, 0.82);
    --bg-strong: #fff9f1;
    --text: #1f1a17;
    --muted: #65594e;
    --line: rgba(81, 63, 45, 0.16);
    --accent: #9b5c2f;
    --accent-strong: #5f2f16;
    --accent-soft: rgba(155, 92, 47, 0.12);
    --shadow: 0 24px 60px rgba(68, 43, 23, 0.12);
    --hero: linear-gradient(135deg, rgba(212, 164, 118, 0.35), rgba(100, 139, 155, 0.2));
    --page-width: min(1160px, calc(100vw - 2rem));
    --heading-font: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --body-font: "Aptos", "Segoe UI", "Trebuchet MS", sans-serif;
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --bg: #111417;
    --bg-elevated: rgba(25, 31, 35, 0.82);
    --bg-strong: #181e23;
    --text: #f4ede4;
    --muted: #c6b9aa;
    --line: rgba(231, 214, 194, 0.12);
    --accent: #d9a36d;
    --accent-strong: #f6d2a9;
    --accent-soft: rgba(217, 163, 109, 0.14);
    --shadow: 0 26px 60px rgba(0, 0, 0, 0.35);
    --hero: linear-gradient(135deg, rgba(217, 163, 109, 0.18), rgba(85, 129, 151, 0.18));
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--body-font);
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(163, 132, 104, 0.18), transparent 28%),
      radial-gradient(circle at bottom right, rgba(73, 116, 134, 0.16), transparent 24%),
      var(--bg);
  }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  .site-shell { position: relative; min-height: 100vh; overflow: hidden; }
  .ambient { position: fixed; border-radius: 999px; filter: blur(40px); opacity: 0.7; pointer-events: none; z-index: 0; }
  .ambient-one { top: 5rem; left: -4rem; width: 18rem; height: 18rem; background: rgba(187, 129, 82, 0.16); }
  .ambient-two { right: -5rem; bottom: 8rem; width: 22rem; height: 22rem; background: rgba(71, 124, 145, 0.16); }
  .site-header, .page-frame, .site-footer { position: relative; z-index: 1; width: var(--page-width); margin-inline: auto; }
  .site-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 0 0.5rem; }
  .brand { display: inline-flex; align-items: center; gap: 0.9rem; }
  .brand-mark { display: grid; place-items: center; width: 3rem; height: 3rem; border-radius: 18px; border: 1px solid var(--line); background: var(--bg-elevated); box-shadow: var(--shadow); font-family: var(--heading-font); font-weight: 700; letter-spacing: 0.08em; overflow: hidden; }
  .brand-mark--image img { width: 100%; height: 100%; object-fit: cover; }
  .brand-copy { display: grid; gap: 0.1rem; }
  .brand-copy strong { font-size: 0.98rem; }
  .brand-copy small { color: var(--muted); font-size: 0.82rem; }
  .site-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; padding: 0.45rem; border: 1px solid var(--line); border-radius: 999px; background: var(--bg-elevated); backdrop-filter: blur(14px); }
  .site-nav a { padding: 0.65rem 1rem; border-radius: 999px; color: var(--muted); transition: background-color 180ms ease, color 180ms ease, transform 180ms ease; }
  .site-nav a:hover, .site-nav a:focus-visible, .site-nav a.active { color: var(--text); background: var(--accent-soft); transform: translateY(-1px); }
  .theme-toggle { border: 1px solid var(--line); background: var(--bg-elevated); color: var(--text); border-radius: 999px; padding: 0.35rem; cursor: pointer; backdrop-filter: blur(14px); }
  .theme-toggle__track { display: inline-flex; align-items: center; gap: 0.3rem; }
  .theme-toggle__icon { padding: 0.55rem 0.75rem; border-radius: 999px; font-size: 0.82rem; }
  [data-theme="light"] .theme-toggle__icon--sun, [data-theme="dark"] .theme-toggle__icon--moon { background: var(--accent-soft); color: var(--accent-strong); }
  .page-frame { padding: 1.25rem 0 3rem; }
  .page-stack { display: grid; gap: 1.25rem; }
  .hero-card, .content-card, .list-card, .timeline-card, .article-card, .note-card { position: relative; overflow: hidden; border: 1px solid var(--line); border-radius: 28px; background: var(--bg-elevated); box-shadow: var(--shadow); backdrop-filter: blur(14px); }
  .hero-card::before, .content-card::before, .list-card::before, .timeline-card::before, .article-card::before, .note-card::before { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 28%); pointer-events: none; }
  .hero-card { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.9fr); gap: 1.5rem; padding: 1.6rem; background-image: var(--hero); }
  .eyebrow { color: var(--accent-strong); font-size: 0.82rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; }
  h1, h2, h3 { margin: 0; font-family: var(--heading-font); line-height: 1.05; }
  h1 { font-size: clamp(2.8rem, 8vw, 4.8rem); max-width: 12ch; }
  h2 { font-size: clamp(1.7rem, 4vw, 2.4rem); }
  h3 { font-size: 1.2rem; }
  p { margin: 0; color: var(--muted); line-height: 1.72; }
  .hero-copy { display: grid; gap: 1rem; align-content: start; }
  .lede { max-width: 62ch; font-size: 1.02rem; }
  .pill-row, .meta-row, .social-grid, .stats-grid, .card-grid, .publication-grid, .projects-grid, .articles-grid { display: grid; gap: 1rem; }
  .pill-row, .meta-row, .cta-row { display: flex; flex-wrap: wrap; }
  .cta-row { gap: 0.8rem; }
  .pill { position: relative; display: inline-flex; align-items: center; gap: 0.45rem; padding: 0.25rem 0 0.4rem 1.1rem; border: 0; border-radius: 0; background: transparent; color: var(--text); font-size: 0.98rem; line-height: 1.5; }
  .pill::before { content: ""; position: absolute; left: 0; top: 0.65rem; width: 0.45rem; height: 0.45rem; border-radius: 999px; background: var(--accent); box-shadow: 0 0 0 6px var(--accent-soft); }
  .hero-aside, .profile-card, .content-card, .list-card, .timeline-card, .article-card, .note-card { padding: 1.35rem; }
  .profile-card { display: grid; gap: 1rem; align-content: start; }
  .portrait { position: relative; aspect-ratio: 4 / 5; border-radius: 24px; overflow: hidden; border: 1px solid var(--line); background: radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.3), transparent 24%), linear-gradient(155deg, #8d5a37, #315968); }
  .portrait img { width: 100%; height: 100%; object-fit: cover; }
  .portrait__fallback { position: absolute; inset: 0; display: grid; place-items: end start; padding: 1.2rem; color: #fdf7ef; }
  .portrait__fallback strong { font-family: var(--heading-font); font-size: clamp(2.6rem, 5vw, 4rem); }
  .portrait__fallback span { display: block; max-width: 14ch; font-size: 0.88rem; opacity: 0.88; }
  .social-grid, .stats-grid, .card-grid, .publication-grid, .projects-grid, .articles-grid { grid-template-columns: repeat(12, minmax(0, 1fr)); }
  .social-link, .stat-card, .detail-card { border: 1px solid var(--line); border-radius: 22px; background: var(--bg-strong); padding: 1rem; }
  .social-link { display: flex; align-items: center; justify-content: space-between; gap: 1rem; min-height: 100%; transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease; cursor: pointer; }
  .social-link::after { content: "↗"; display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 999px; border: 1px solid var(--line); color: var(--accent-strong); background: var(--accent-soft); font-size: 1rem; flex-shrink: 0; }
  .social-link:hover, .social-link:focus-visible { transform: translateY(-3px); border-color: rgba(155, 92, 47, 0.4); box-shadow: 0 18px 32px rgba(68, 43, 23, 0.12); background: color-mix(in srgb, var(--bg-strong) 90%, var(--accent-soft)); }
  .social-link:focus-visible { outline: 2px solid rgba(155, 92, 47, 0.28); outline-offset: 2px; }
  .social-link--disabled { opacity: 0.65; cursor: not-allowed; }
  .social-link--disabled::after { content: "•"; }
  .social-link span:first-child, .stat-card strong, .detail-card strong, .publication-card strong, .timeline-card strong, .article-card strong { color: var(--text); }
  .social-link small, .stat-card small, .detail-card small, .publication-card small, .timeline-card small, .article-card small, .tag { color: var(--muted); }
  .social-grid > *, .stats-grid > *, .card-grid > * { grid-column: span 6; }
  .publication-card, .timeline-card, .article-card { display: grid; gap: 0.85rem; }
  .publication-grid > *, .projects-grid > *, .articles-grid > * { grid-column: span 12; }
  .section-heading { display: grid; gap: 0.55rem; margin-bottom: 0.85rem; }
  .section-heading p { max-width: 66ch; }
  .split-layout { display: grid; grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr); gap: 1rem; }
  .detail-stack { display: grid; gap: 1rem; }
  .meta-chip, .tag { display: inline-flex; align-items: center; padding: 0.45rem 0.8rem; border-radius: 999px; border: 1px solid var(--line); background: var(--accent-soft); font-size: 0.84rem; }
  .button-link, .button-ghost { display: inline-flex; align-items: center; justify-content: center; gap: 0.45rem; padding: 0.85rem 1.2rem; border-radius: 999px; border: 1px solid transparent; font-weight: 600; cursor: pointer; }
  .button-link { background: var(--accent-strong); color: #fdf6ed; }
  .button-ghost { border-color: var(--line); background: transparent; color: var(--text); }
  .publication-card__footer, .article-card__footer { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; }
  .timeline-card__date { color: var(--accent-strong); font-size: 0.9rem; font-weight: 700; }
  ul.clean-list { margin: 0; padding-left: 1.1rem; color: var(--muted); display: grid; gap: 0.55rem; line-height: 1.68; }
  .site-footer { display: flex; justify-content: space-between; gap: 1rem; padding: 0 0 2.2rem; color: var(--muted); font-size: 0.92rem; }
  dialog.article-dialog { width: min(900px, calc(100vw - 1.5rem)); max-height: min(88vh, 980px); padding: 0; border: 1px solid var(--line); border-radius: 28px; background: var(--bg-strong); color: var(--text); box-shadow: var(--shadow); }
  dialog.article-dialog::backdrop { background: rgba(10, 12, 14, 0.65); backdrop-filter: blur(4px); }
  .article-dialog__inner { display: grid; gap: 1.2rem; padding: 1.5rem; }
  .article-dialog__header { display: flex; justify-content: space-between; gap: 1rem; align-items: start; }
  .article-dialog__content { display: grid; gap: 1rem; overflow: auto; padding-right: 0.35rem; }
  .article-dialog__content blockquote { margin: 0; padding: 1rem 1.1rem; border-left: 3px solid var(--accent); background: var(--accent-soft); border-radius: 0 18px 18px 0; font-family: var(--heading-font); color: var(--text); }
  @media (max-width: 960px) {
    .site-header, .site-footer { flex-direction: column; align-items: stretch; }
    .hero-card, .split-layout { grid-template-columns: 1fr; }
    .site-nav { justify-content: flex-start; border-radius: 24px; }
    .theme-toggle { align-self: flex-start; }
  }
  @media (max-width: 720px) {
    .social-grid > *, .stats-grid > *, .card-grid > * { grid-column: span 12; }
    .hero-card, .profile-card, .content-card, .list-card, .timeline-card, .article-card, .note-card { padding: 1.05rem; border-radius: 24px; }
    h1 { max-width: 10ch; }
  }
</style>
